# Render backend environment variables (Dashboard → Environment)

# Supabase Session Pooler connection string (Project Settings → Database → Connection string).
# Format: postgresql://postgres.<ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Slack incoming webhook for lead alerts.
SLACK_WEBHOOK_URL=

# Resend API key and verified sender for lead notification emails.
RESEND_API_KEY=
RESEND_FROM_EMAIL=intel@shivanchal.in
